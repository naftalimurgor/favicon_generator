#!/usr/bin/env bash

set -euo pipefail

# ==========================
# Usage check
# ==========================
if [[ $# -lt 2 ]]; then
  echo "Usage: $0 <input-image> <output-directory>"
  exit 1
fi

INPUT="$1"
OUTDIR="$2"

# ==========================
# Validate input
# ==========================
if [[ ! -f "$INPUT" ]]; then
  echo "Error: Input file not found -> $INPUT"
  exit 1
fi

# ==========================
# Prepare output directory
# ==========================
mkdir -p "$OUTDIR"

echo "Generating favicons..."
echo "Input:  $INPUT"
echo "Output: $OUTDIR"

# ==========================
# Generate PNG sizes
# ==========================
convert "$INPUT" -resize 16x16   "$OUTDIR/favicon-16x16.png"
convert "$INPUT" -resize 32x32   "$OUTDIR/favicon-32x32.png"
convert "$INPUT" -resize 180x180 "$OUTDIR/apple-touch-icon.png"
convert "$INPUT" -resize 192x192 "$OUTDIR/android-chrome-192x192.png"
convert "$INPUT" -resize 512x512 "$OUTDIR/android-chrome-512x512.png"

# ==========================
# Generate ICO (multi-size)
# ==========================
convert "$INPUT" -define icon:auto-resize=16,32,48 "$OUTDIR/favicon.ico"

# ==========================
# Optional: manifest helper
# ==========================
cat > "$OUTDIR/site.webmanifest" <<EOF
{
  "name": "Bitgesell Snapshot",
  "short_name": "BGL Snapshot",
  "icons": [
    {
      "src": "/favicons/android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/favicons/android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "theme_color": "#0b1220",
  "background_color": "#0b1220",
  "display": "standalone"
}
EOF

echo "Done ✔ Favicons generated in: $OUTDIR"