#!/usr/bin/env bash

set -euo pipefail

# ==========================
# Usage check
# ==========================
if [[ $# -lt 2 ]]; then
  echo "Usage: $0 <input-image> <output-directory>"
  exit 1
fi

INPUT="$1"
OUTDIR="$2"

# ==========================
# Validate input
# ==========================
if [[ ! -f "$INPUT" ]]; then
  echo "Error: Input file not found -> $INPUT"
  exit 1
fi

# ==========================
# Check ImageMagick
# ==========================
if ! command -v magick >/dev/null 2>&1; then
  echo "ImageMagick is required but not installed."

  if command -v pacman >/dev/null 2>&1; then
    read -rp "Install ImageMagick now? [Y/n]: " reply
    reply=${reply:-Y}

    if [[ "$reply" =~ ^[Yy]$ ]]; then
      sudo pacman -S --needed imagemagick
    else
      echo "Aborted."
      exit 1
    fi
  else
    echo "Please install ImageMagick using your package manager."
    exit 1
  fi
fi

# ==========================
# Prepare output directory
# ==========================
mkdir -p "$OUTDIR"

echo "Generating favicons..."
echo "Using:   $(magick -version | head -n1)"
echo "Input:   $INPUT"
echo "Output:  $OUTDIR"

# ==========================
# Generate PNG sizes
# ==========================
magick "$INPUT" -resize 16x16   "$OUTDIR/favicon-16x16.png"
magick "$INPUT" -resize 32x32   "$OUTDIR/favicon-32x32.png"
magick "$INPUT" -resize 180x180 "$OUTDIR/apple-touch-icon.png"
magick "$INPUT" -resize 192x192 "$OUTDIR/android-chrome-192x192.png"
magick "$INPUT" -resize 512x512 "$OUTDIR/android-chrome-512x512.png"

# ==========================
# Generate ICO (multi-size)
# ==========================
magick "$INPUT" \
  -define icon:auto-resize=16,32,48 \
  "$OUTDIR/favicon.ico"

# ==========================
# Generate web manifest
# ==========================
cat > "$OUTDIR/site.webmanifest" <<EOF
{
  "name": "Bitgesell Snapshot",
  "short_name": "BGL Snapshot",
  "icons": [
    {
      "src": "/favicons/android-chrome-192x192.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/favicons/android-chrome-512x512.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "theme_color": "#0b1220",
  "background_color": "#0b1220",
  "display": "standalone"
}
EOF

echo
echo "✔ Done! Favicons generated in:"
echo "  $OUTDIR"